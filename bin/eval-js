#!/bin/bash
# eval-js — Execute JavaScript in the browser
# Usage: eval-js <expression>
#        eval-js --file <path>
#
# Returns the result of the last expression.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../lib/browse-helper.sh"

if [ "${1:-}" = "--file" ]; then
  FILE="${2:?Usage: eval-js --file <path>}"
  $B eval "$FILE" 2>/dev/null
else
  EXPR="${1:?Usage: eval-js <expression>}"
  $B js "$EXPR" 2>/dev/null
fi

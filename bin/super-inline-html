#!/bin/bash
# super-inline-html — Bundle HTML + all referenced assets into a single self-contained file
# Usage: super-inline-html --input <html_file> --output <output_file>
#
# Inlines:
#   - CSS (<link rel="stylesheet">) → <style>
#   - JavaScript (<script src>) → <script>
#   - Images (<img src>) → data: URIs
#   - Fonts (@font-face url()) → data: URIs (local files only)
#
# Remote resources (CDN scripts, Google Fonts) are kept as-is.

set -euo pipefail

INPUT=""
OUTPUT=""

while [ $# -gt 0 ]; do
  case "$1" in
    --input)  INPUT="$2"; shift 2 ;;
    --output) OUTPUT="$2"; shift 2 ;;
    *)        echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

INPUT="${INPUT:?Usage: super-inline-html --input <file> --output <file>}"
OUTPUT="${OUTPUT:?Usage: super-inline-html --input <file> --output <file>}"

if [ ! -f "$INPUT" ]; then
  echo "ERROR: Input file not found: $INPUT" >&2
  exit 1
fi

export INPUT OUTPUT
python3 << 'PYSCRIPT'
import re, os, sys, base64, mimetypes

input_path = os.environ.get('INPUT', '')
output_path = os.environ.get('OUTPUT', '')

if not input_path or not output_path:
    print("ERROR: Missing input/output", file=sys.stderr)
    sys.exit(1)

base_dir = os.path.dirname(os.path.abspath(input_path))

with open(input_path, 'r', encoding='utf-8') as f:
    html = f.read()

inlined_count = 0

# Inline CSS files
def inline_css(match):
    global inlined_count
    href = match.group(1)
    if href.startswith(('http://', 'https://', '//')):
        return match.group(0)
    css_path = os.path.join(base_dir, href)
    if os.path.exists(css_path):
        with open(css_path, 'r', encoding='utf-8') as f:
            css = f.read()
        inlined_count += 1
        return f'<style>/* Inlined: {href} */\n{css}\n</style>'
    return match.group(0)

html = re.sub(
    r'<link\s+[^>]*href=["\']([^"\']+\.css)["\'][^>]*>',
    inline_css, html
)

# Inline JS files
def inline_js(match):
    global inlined_count
    full_tag = match.group(0)
    src = match.group(1)
    if src.startswith(('http://', 'https://', '//')):
        return full_tag
    js_path = os.path.join(base_dir, src)
    if os.path.exists(js_path):
        with open(js_path, 'r', encoding='utf-8') as f:
            js = f.read()
        inlined_count += 1
        # Preserve type attribute if present
        type_match = re.search(r'type=["\']([^"\']+)["\']', full_tag)
        type_attr = f' type="{type_match.group(1)}"' if type_match else ''
        return f'<script{type_attr}>/* Inlined: {src} */\n{js}\n</script>'
    return full_tag

html = re.sub(
    r'<script\s+[^>]*src=["\']([^"\']+)["\'][^>]*>\s*</script>',
    inline_js, html
)

# Inline images
def inline_img(match):
    global inlined_count
    full_tag = match.group(0)
    src = match.group(1)
    if src.startswith(('http://', 'https://', '//', 'data:')):
        return full_tag
    img_path = os.path.join(base_dir, src)
    if os.path.exists(img_path):
        mime, _ = mimetypes.guess_type(img_path)
        if mime and mime.startswith('image/'):
            with open(img_path, 'rb') as f:
                data = base64.b64encode(f.read()).decode()
            inlined_count += 1
            return full_tag.replace(src, f'data:{mime};base64,{data}')
    return full_tag

html = re.sub(
    r'<img\s+[^>]*src=["\']([^"\']+)["\'][^>]*>',
    inline_img, html
)

# Write output
output_dir = os.path.dirname(os.path.abspath(output_path))
if output_dir and not os.path.exists(output_dir):
    os.makedirs(output_dir)

with open(output_path, 'w', encoding='utf-8') as f:
    f.write(html)

size = os.path.getsize(output_path)
print(f"Bundled: {output_path}")
print(f"Inlined {inlined_count} assets")
print(f"Size: {size:,} bytes ({size/1024:.1f} KB)")
PYSCRIPT

#!/bin/bash
# open-for-print — Open HTML file for printing/PDF export
# Usage: open-for-print <path>
#
# Opens the file in the default browser. The user can then
# press Cmd+P (Mac) or Ctrl+P (Windows) to save as PDF.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

FILE_PATH="${1:?Usage: open-for-print <path>}"

# Resolve to absolute path
if [[ "$FILE_PATH" != /* ]]; then
  FILE_PATH="$(pwd)/$FILE_PATH"
fi

if [ ! -f "$FILE_PATH" ]; then
  echo "ERROR: File not found: $FILE_PATH" >&2
  exit 1
fi

# Also try to generate PDF directly via browse if available
source "$SCRIPT_DIR/../lib/browse-helper.sh" 2>/dev/null || true

if [ -n "${B:-}" ]; then
  PDF_PATH="${FILE_PATH%.html}.pdf"
  # Navigate to the file
  PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || dirname "$FILE_PATH")
  source "$SCRIPT_DIR/../lib/server.sh"
  if ! server_is_running; then
    server_start "$PROJECT_ROOT"
  fi
  REL_PATH="${FILE_PATH#$PROJECT_ROOT/}"
  URL=$(server_url "$REL_PATH")
  $B goto "$URL" 2>/dev/null
  sleep 2
  $B pdf "$PDF_PATH" 2>/dev/null && echo "PDF saved: $PDF_PATH" || true
fi

# Open in browser for manual print
open "$FILE_PATH" 2>/dev/null || xdg-open "$FILE_PATH" 2>/dev/null || true
echo "Opened for printing: $FILE_PATH"
echo "Press Cmd+P (Mac) or Ctrl+P (Windows) to save as PDF"
